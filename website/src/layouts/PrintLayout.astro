---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} | Bridge Bidding Systems</title>
  </head>
  <body class="print-body">
    <div class="print-preview-banner no-print">
      Use your browser's Print function (Ctrl+P / Cmd+P) to print or save as PDF.
      <a href="/bridge-docs/downloads/" class="print-preview-link">Back to Downloads</a>
    </div>

    <header class="print-layout-header">
      <h1 class="print-title">{title}</h1>
      {subtitle && <p class="print-subtitle">{subtitle}</p>}
      <div class="print-header-rule"></div>
    </header>

    <main>
      <slot />
    </main>

    <style is:global>
      @import "tailwindcss";
      @import "../styles/print.css";

      .print-body {
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 0.8rem;
        line-height: 1.4;
        color: #0a0a0a;
        background: #ffffff;
        max-width: 210mm;
        margin: 0 auto;
        padding: 16px;
      }

      .print-title {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin: 0;
      }

      .print-subtitle {
        font-size: 0.7rem;
        color: #737373;
        margin: 2px 0 0 0;
      }

      .print-header-rule {
        height: 2px;
        background: #171717;
        margin-top: 6px;
        margin-bottom: 12px;
      }

      .print-preview-banner {
        background-color: #fef3c7;
        border: 1px solid #f59e0b;
        border-radius: 6px;
        padding: 12px 16px;
        margin-bottom: 24px;
        font-size: 0.875rem;
        color: #92400e;
      }

      .print-preview-link {
        margin-left: 12px;
        color: #92400e;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      @media print {
        .print-body {
          max-width: none;
          margin: 0;
          padding: 0;
        }
      }
    </style>
  </body>
</html>
