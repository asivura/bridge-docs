        description: "In-depth bridge studies, puzzles, and encyclopedic reference material",
      },
    ],
  },
  {
    id: "video-resources",
    title: "Video Resources",
    resources: [
      {
        name: "Bridge with Pete (Pete Hollands)",
        url: "https://www.youtube.com/@PeteHollandsBridge",
        type: "video",
