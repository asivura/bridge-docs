const tocItems = sections.map((s) => ({ id: s.id, label: s.title }));

const typeBadgeClass: Record<string, string> = {
  website: "bg-blue-100 text-blue-800 border-blue-200",
  book: "bg-amber-100 text-amber-800 border-amber-200",
  app: "bg-purple-100 text-purple-800 border-purple-200",
  video: "bg-rose-100 text-rose-800 border-rose-200",
};

const costBadgeClass: Record<string, string> = {
  Free: "bg-emerald-100 text-emerald-800 border-emerald-200",
  Paid: "bg-gray-100 text-gray-700 border-gray-200",
  "Free/Paid": "bg-teal-100 text-teal-800 border-teal-200",
};

const levelBadgeClass: Record<string, string> = {
  Beginner: "bg-green-100 text-green-800 border-green-200",
  Intermediate: "bg-sky-100 text-sky-800 border-sky-200",
  Advanced: "bg-orange-100 text-orange-800 border-orange-200",
  All: "bg-gray-100 text-gray-600 border-gray-200",
};
---

<BaseLayout title="Resources" description="Curated educational resources for learning bridge bidding, SAYC conventions, and improving your game.">
  <div class="space-y-2">
    <h1 class="text-3xl font-bold tracking-tight">Resources</h1>
    <p class="text-muted-foreground">
      Curated resources for learning bridge, practicing SAYC, and improving your game.
    </p>
  </div>

  <!-- Start Here callout -->
  <div class="mt-6 rounded-lg border-2 border-primary/20 bg-primary/5 p-5">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-primary">Start Here</h2>
    <p class="mt-1 text-sm text-muted-foreground">
      Transitioning from our partnership system to SAYC? These three resources will get you up to speed fastest:
    </p>
    <ol class="mt-3 space-y-2 text-sm">
      <li class="flex items-start gap-2">
        <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">1</span>
        <span>
          <a href="https://web2.acbl.org/documentlibrary/play/SP3%20(bk)%20single%20pages.pdf" target="_blank" rel="noopener" class="font-medium underline underline-offset-4 hover:text-foreground">ACBL SAYC Booklet</a>
          — The official reference. Read this alongside our
          <a href="/bridge-docs/differences/" class="font-medium underline underline-offset-4 hover:text-foreground">Differences</a> page.
        </span>
      </li>
      <li class="flex items-start gap-2">
        <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">2</span>
        <span>
          <a href="http://www.saycbridge.com/" target="_blank" rel="noopener" class="font-medium underline underline-offset-4 hover:text-foreground">SAYCBridge.com</a>
          — Practice SAYC bidding with an AI bot that explains its reasoning.
        </span>
      </li>
      <li class="flex items-start gap-2">
        <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">3</span>
        <span>
          <a href="https://www.bridgebase.com/" target="_blank" rel="noopener" class="font-medium underline underline-offset-4 hover:text-foreground">Bridge Base Online</a>
          — Play SAYC hands against robots or real opponents to build muscle memory.
        </span>
      </li>
    </ol>
  </div>

  <!-- Badge legend (clickable filters) -->
  <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-muted-foreground">
    <span class="font-medium">Filter:</span>
    <span class="flex items-center gap-1.5">
      <button data-filter="type:website" class:list={["inline-flex cursor-pointer items-center rounded-full border px-2 py-0.5 text-xs font-medium transition-all hover:opacity-80", typeBadgeClass.website]}>Website</button>
      <button data-filter="type:book" class:list={["inline-flex cursor-pointer items-center rounded-full border px-2 py-0.5 text-xs font-medium transition-all hover:opacity-80", typeBadgeClass.book]}>Book</button>
      <button data-filter="type:app" class:list={["inline-flex cursor-pointer items-center rounded-full border px-2 py-0.5 text-xs font-medium transition-all hover:opacity-80", typeBadgeClass.app]}>App</button>
      <button data-filter="type:video" class:list={["inline-flex cursor-pointer items-center rounded-full border px-2 py-0.5 text-xs font-medium transition-all hover:opacity-80", typeBadgeClass.video]}>Video</button>
    </span>
    <span class="flex items-center gap-1.5">
      <button data-filter="cost:free" class:list={["inline-flex cursor-pointer items-center rounded-full border px-2 py-0.5 text-xs font-medium transition-all hover:opacity-80", costBadgeClass.Free]}>Free</button>
      <button data-filter="cost:paid" class:list={["inline-flex cursor-pointer items-center rounded-full border px-2 py-0.5 text-xs font-medium transition-all hover:opacity-80", costBadgeClass.Paid]}>Paid</button>
      <button data-filter="cost:free/paid" class:list={["inline-flex cursor-pointer items-center rounded-full border px-2 py-0.5 text-xs font-medium transition-all hover:opacity-80", costBadgeClass["Free/Paid"]]}>Free/Paid</button>
    </span>
    <button data-filter-clear class="hidden cursor-pointer text-xs font-medium text-primary underline underline-offset-2 hover:text-primary/80">Clear filters</button>
  </div>

  <div class="mt-8 flex gap-8">
    <!-- Main content -->
    <div class="min-w-0 flex-1 space-y-8">
      {sections.map((section) => (
        <div
          id={section.id}
          data-toc-target
          data-resource-section
          class="scroll-mt-4"
        >
          <div class="rounded-xl border bg-card shadow-sm">
            <div class="border-b px-6 py-4">
              <h2 class="text-lg font-semibold">{section.title}</h2>
              {section.note && (
                <p class="mt-1 text-sm text-muted-foreground">{section.note}</p>
              )}
            </div>
            <div class="divide-y">
              {section.resources.map((r) => (
                <div
                  data-resource
                  data-type={r.type}
                  data-cost={r.cost.toLowerCase().replace("/", "/")}
                  data-level={r.level.toLowerCase()}
                  class="flex flex-col gap-2 px-6 py-4 sm:flex-row sm:items-start sm:gap-4"
                >
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                      {r.url ? (
                        <a
                          href={r.url}
                          target="_blank"
                          rel="noopener"
                          class="font-medium underline underline-offset-4 hover:text-primary"
                        >
                          {r.name}
                        </a>
                      ) : (
                        <span class="font-medium">{r.name}</span>
                      )}
                      <span class:list={["inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium", typeBadgeClass[r.type]]}>
                        {r.type.charAt(0).toUpperCase() + r.type.slice(1)}
                      </span>
                      <span class:list={["inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium", costBadgeClass[r.cost]]}>
                        {r.cost}
                      </span>
                      <span class:list={["inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium", levelBadgeClass[r.level]]}>
                        {r.level}
                      </span>
                    </div>
                    <p class="mt-1 text-sm text-muted-foreground">{r.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Sidebar TOC -->
    <TableOfContents items={tocItems} />
  </div>

  <div class="mt-8 text-center">
    <a
      href="/bridge-docs/downloads/"
      class="text-sm font-medium text-primary underline-offset-4 hover:underline"
    >
      Download printable convention cards &rarr;
    </a>
  </div>

  <script is:inline>
  (function() {
    var filters = {};
    var resources = document.querySelectorAll('[data-resource]');
    var buttons = document.querySelectorAll('[data-filter]');
    var clearBtn = document.querySelector('[data-filter-clear]');

    function applyFilters() {
      resources.forEach(function(el) {
        var visible = true;
        for (var key in filters) {
          if (el.dataset[key] !== filters[key]) {
            visible = false;
            break;
          }
        }
        el.style.display = visible ? '' : 'none';
      });

      buttons.forEach(function(btn) {
        var parts = btn.dataset.filter.split(':');
        var key = parts[0];
        var value = parts[1];
        var isActive = filters[key] === value;
        btn.classList.toggle('ring-2', isActive);
        btn.classList.toggle('ring-offset-1', isActive);
        btn.classList.toggle('opacity-100', isActive);
        if (isActive) {
          btn.style.boxShadow = '0 0 0 2px hsl(var(--primary))';
        } else {
          btn.style.boxShadow = '';
        }
      });

      if (clearBtn) {
        clearBtn.style.display = Object.keys(filters).length > 0 ? '' : 'none';
      }

      document.querySelectorAll('[data-resource-section]').forEach(function(section) {
        var visibleItems = section.querySelectorAll('[data-resource]:not([style*="display: none"])');
        section.style.display = visibleItems.length > 0 ? '' : 'none';
      });
    }

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var parts = btn.dataset.filter.split(':');
        var key = parts[0];
        var value = parts[1];
        if (filters[key] === value) {
          delete filters[key];
        } else {
          filters[key] = value;
        }
        applyFilters();
      });
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        Object.keys(filters).forEach(function(k) { delete filters[k]; });
        applyFilters();
      });
    }
  })();
  </script>
</BaseLayout>
