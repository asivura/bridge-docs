---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { Badge } from "@/components/ui/badge";
import "@/styles/global.css";

interface Resource {
  name: string;
  url?: string;
  type: "website" | "book" | "app" | "video";
  cost: "Free" | "Paid" | "Free/Paid";
  level: "Beginner" | "Intermediate" | "Advanced" | "All";
  description: string;
}

interface Section {
  id: string;
  title: string;
  note?: string;
  resources: Resource[];
}

const sections: Section[] = [
  {
    id: "getting-started",
    title: "Getting Started",
    resources: [
      {
        name: "ACBL SAYC Booklet",
        url: "https://web2.acbl.org/documentlibrary/play/SP3%20(bk)%20single%20pages.pdf",
        type: "website",
        cost: "Free",
        level: "Beginner",
        description: "Official ACBL Standard American Yellow Card reference booklet (PDF)",
      },
      {
        name: "My Bridge Buddy",
        url: "https://mybridgebuddy.com/",
        type: "website",
        cost: "Free",
        level: "Beginner",
