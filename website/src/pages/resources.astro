      },
      {
        name: "Larry Cohen Articles",
        url: "https://www.larryco.com/bridge-articles/",
        type: "website",
        cost: "Free",
        level: "Intermediate",
        description: "Extensive article library covering conventions, bidding, and strategy",
      },
      {
        name: "ACBL Convention PDFs",
        url: "http://web2.acbl.org/documentLibrary/play/Commonly_Used_Conventions/",
        type: "website",
        cost: "Free",
        level: "All",
        description: "Official ACBL downloadable PDFs for commonly used conventions",
      },
    ],
  },
  {
    id: "community",
    title: "Community",
    resources: [
      {
        name: "BBO Forums",
        url: "https://www.bridgebase.com/forums/",
        type: "website",
        cost: "Free",
        level: "All",
        description: "Active discussion forums on the largest online bridge platform",
      },
      {
        name: "Bridge on Discord",
        url: "https://discord.com/invite/uS22xhpawf",
        type: "website",
        cost: "Free",
        level: "All",
        description: "Discord community for real-time bridge discussion and finding partners",
      },
      {
        name: "Bridge Winners Forums",
        url: "https://bridgewinners.com/",
        type: "website",
        cost: "Free",
        level: "Intermediate",
        description: "Expert-level forums with bidding polls and hand analysis",
      },
      {
        name: "Great Bridge Links",
