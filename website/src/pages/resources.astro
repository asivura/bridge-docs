        description: "iOS quiz app focused specifically on SAYC bidding scenarios",
      },
      {
        name: "BridgeBee",
        url: "https://bridgebee.app/",
        type: "app",
        cost: "Free",
        level: "Beginner",
        description: "Modern bridge practice app with guided lessons",
      },
    ],
  },
  {
    id: "russian-resources",
    title: "Russian Resources",
    note: "These resources are in Russian (Русские ресурсы). Useful for players familiar with Russian bridge tradition, which our partnership system is based on.",
    resources: [
      {
        name: "Bridge Academy (bridgeacadem.ru)",
        url: "https://bridgeacadem.ru/online",
        type: "website",
