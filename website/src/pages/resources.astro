        level: "Intermediate",
        description: "Structured video lessons from professional bridge player and commentator",
      },
      {
        name: "WBF on Twitch",
        url: "https://www.twitch.tv/directory/game/Bridge",
        type: "video",
        cost: "Free",
        level: "All",
        description: "Live world championship bridge coverage with expert commentary",
      },
      {
        name: "Great Bridge Links Video Directory",
        url: "https://greatbridgelinks.com/gblrsc/bridge-videos/",
        type: "video",
        cost: "Free",
        level: "All",
        description: "Curated directory of bridge video resources across the web",
      },
    ],
  },
  {
    id: "books",
    title: "Books",
    resources: [
      {
        name: "Standard Bidding with SAYC",
        type: "book",
        cost: "Paid",
        level: "Beginner",
        description: "Downey & Pomer's definitive guide to SAYC bidding, the essential reference",
      },
      {
        name: "25 Bridge Conventions You Should Know",
        type: "book",
        cost: "Paid",
