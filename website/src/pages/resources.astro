        type: "website",
        cost: "Free",
        level: "Intermediate",
        description: "Community site with expert discussions, articles, and bidding polls",
      },
      {
        name: "60 Second Bridge",
        url: "https://www.60secondbridge.com/",
        type: "website",
        cost: "Free",
        level: "Beginner",
        description: "Quick daily bridge lessons and tips in bite-sized format",
      },
      {
        name: "No Fear Bridge",
        url: "https://www.nofearbridge.com/",
        type: "website",
        cost: "Free/Paid",
        level: "Beginner",
        description: "Structured lessons and practice for new players",
      },
      {
        name: "Larry Cohen's Bridge",
        url: "https://www.larryco.com/",
