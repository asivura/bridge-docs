---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/global.css";

const downloads = [
  {
    title: "Our Partnership System",
    description:
      "Complete convention card for our partnership bidding system based on Russian bridge tradition with custom HCP ranges.",
    pdfHref: "/bridge-docs/downloads/our-system-convention-card.pdf",
  },
  {
    title: "Standard SAYC",
    description:
      "Clean SAYC convention card reference for use at the table.",
    pdfHref: "/bridge-docs/downloads/sayc-convention-card.pdf",
  },
  {
    title: "Transition Guide: Our System → SAYC",
    description:
      "SAYC convention card with detailed annotations explaining every difference from our partnership system. 48 annotated changes with severity levels and practical tips.",
    pdfHref: "/bridge-docs/downloads/transition-guide.pdf",
  },
];
---

<BaseLayout title="Downloads">
  <div class="space-y-2">
    <h1 class="text-3xl font-bold tracking-tight">Downloads</h1>
    <p class="text-muted-foreground">
      Printable convention cards generated from the latest system documentation.
    </p>
  </div>

  <div class="mt-8 grid gap-6 sm:grid-cols-3">
    {downloads.map((dl) => (
      <div class="rounded-lg border bg-card p-6 flex flex-col">
        <div class="flex-1">
          <h2 class="text-lg font-semibold">{dl.title}</h2>
          <p class="mt-1 text-sm text-muted-foreground">{dl.description}</p>
        </div>

        <div class="mt-4">
          <a
            href={dl.pdfHref}
            class="inline-flex w-full items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            Download PDF
          </a>
        </div>
      </div>
    ))}
  </div>

  <div class="mt-8 rounded-lg border border-border/50 bg-muted/50 p-4 text-sm text-muted-foreground">
    <p>
      <strong>Note:</strong> PDFs are generated from the latest system documentation.
    </p>
  </div>
</BaseLayout>
