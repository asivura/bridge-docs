---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/global.css";

const downloads = [
  {
    title: "Our Partnership System",
    description:
      "Complete convention card for our partnership bidding system based on Russian bridge tradition with custom HCP ranges.",
    printHref: "/bridge-docs/print/our-system/",
    pdfHref: "/bridge-docs/downloads/our-system-convention-card.pdf",
  },
  {
    title: "Standard SAYC",
    description:
      "Standard American Yellow Card reference with annotated differences from our partnership system.",
    printHref: "/bridge-docs/print/sayc/",
    pdfHref: "/bridge-docs/downloads/sayc-convention-card.pdf",
  },
];
---

<BaseLayout title="Downloads">
  <div class="space-y-2">
    <h1 class="text-3xl font-bold tracking-tight">Downloads</h1>
    <p class="text-muted-foreground">
      Printable convention cards generated from the latest system documentation.
    </p>
  </div>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {downloads.map((dl) => (
      <div class="rounded-lg border bg-card p-6 space-y-4">
        <div>
          <h2 class="text-lg font-semibold">{dl.title}</h2>
          <p class="mt-1 text-sm text-muted-foreground">{dl.description}</p>
        </div>

        <div class="flex flex-col gap-2">
          <a
            href={dl.printHref}
            class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            View Printable Version
          </a>
          <a
            href={dl.pdfHref}
            class="inline-flex items-center justify-center rounded-md border bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            Download PDF
          </a>
        </div>
      </div>
    ))}
  </div>

  <div class="mt-8 rounded-lg border border-border/50 bg-muted/50 p-4 text-sm text-muted-foreground">
    <p>
      <strong>Note:</strong> PDFs are generated from the latest markdown content.
      Use the printable versions for the most up-to-date convention cards, or use your browser's
      "Save as PDF" function from the print preview.
    </p>
  </div>
</BaseLayout>
