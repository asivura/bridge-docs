// Group scan sections by page for navigation
const scanByPage = new Map<string, typeof scanSections>();
for (const s of scanSections) {
  const key = `Page ${s.page}`;
  if (!scanByPage.has(key)) scanByPage.set(key, []);
  scanByPage.get(key)!.push(s);
}

// Helper to colorize suit symbols
function formatBid(text: string): string {
  return text
    .replace(/♠/g, '<span style="color: inherit; font-weight: 600;">♠</span>')
    .replace(/♣/g, '<span style="color: inherit; font-weight: 600;">♣</span>')
    .replace(/♥/g, '<span style="color: #dc2626; font-weight: 600;">♥</span>')
    .replace(/♦/g, '<span style="color: #dc2626; font-weight: 600;">♦</span>');
}

// Look up sections by title (exact match or prefix match for sub-sections)
function findSections(titles: string[]) {
  return titles
    .flatMap((t) => ourSystemSections.filter((s) => s.title === t || s.title.startsWith(t + ':')))
    .filter((s): s is NonNullable<typeof s> => s != null);
}

// Pre-compute sequential table numbers across all verification sections
const verificationTableNumbers = new Map<typeof ourSystemSections[number], number>();
let verTableCounter = 1;
for (const scan of scanSections) {
  const matched = findSections(scan.sections);
  for (const section of matched) {
    if (!verificationTableNumbers.has(section)) {
      verificationTableNumbers.set(section, verTableCounter++);
    }
  }
}
---

<BaseLayout title="Verification">
  <div class="space-y-2">
    <h1 class="text-3xl font-bold tracking-tight">Scan Verification</h1>
    <p class="text-muted-foreground">
      Original handwritten convention cards (in Russian) shown alongside
      the transcribed tables. Use this page to spot-check the transcription
      against the source material.
    </p>
  </div>

  <nav class="mt-6 rounded-lg border bg-card p-4">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-muted-foreground">
      Jump to Section
    </h2>
    <div class="space-y-2 text-sm">
      {Array.from(scanByPage.entries()).map(([page, items]) => (
        <div class="flex items-baseline gap-2">
          <span class="inline-flex w-16 shrink-0 items-center justify-center rounded bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">
            {page}
          </span>
          <div class="flex flex-wrap gap-1.5">
            {items.map((s) => (
              <a
                href={`#${s.label.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}
                class="rounded-md border bg-background px-2.5 py-1 text-xs font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
              >
                <span set:html={formatBid(s.label)} />
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </nav>

  <div class="mt-4 rounded-lg border border-amber-300 bg-amber-50 p-4 text-sm">
    <p class="font-medium text-amber-900">
      5 unverified errors (ERR-20 through ERR-24) are flagged below with warnings.
      These need the physical convention card to resolve, as scan quality is insufficient.
    </p>
  </div>

  <div class="mt-8 space-y-12">
    {scanSections.map((scan, idx) => {
      const matched = findSections(scan.sections);
      return (
        <>
          {idx > 0 && <Separator />}
          <section id={scan.label.toLowerCase().replace(/[^a-z0-9]+/g, "-")}>
            <div class="mb-4">
              <h2 class="text-xl font-semibold" set:html={formatBid(scan.label)} />
              <p class="text-sm text-muted-foreground">
                Page {scan.page} &middot; {scan.image} &middot;
                <span class="italic">{scan.russian}</span>
              </p>
              {scan.note && (
                <p class="mt-1 text-sm italic text-muted-foreground">
                  {scan.note}
                </p>
              )}
            </div>

            {scan.warnings.length > 0 && (
              <div class="mb-4 space-y-2">
                {scan.warnings.map((w) => (
                  <Alert variant="destructive">
                    <AlertTitle>{w.id}: {w.title}</AlertTitle>
                    <AlertDescription>{w.description}</AlertDescription>
                  </Alert>
                ))}
              </div>
            )}

            <div class="grid gap-6 lg:grid-cols-2">
              <div class="space-y-2">
                <h3 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">
                  Original Scan
                </h3>
                <a
                  href={`/bridge-docs/scans/${scan.image}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block overflow-hidden rounded-lg border"
                >
                  <img
                    src={`/bridge-docs/scans/${scan.image}`}
                    alt={`Scan of ${scan.label} (${scan.russian})`}
                    class="w-full transition-transform group-hover:scale-105"
                    loading="lazy"
                  />
                  <span class="block bg-muted px-3 py-1.5 text-center text-xs text-muted-foreground">
                    Click to open full image
                  </span>
                </a>
              </div>

              <div class="space-y-2">
                <h3 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">
                  Transcription
                </h3>
                {matched.length > 0 ? (
                  <div class="space-y-4">
                    {matched.map((section) => (
                      <div class="overflow-x-auto">
                        {isBiddingSection(section) ? (
                          <BiddingTable tableNumber={verificationTableNumbers.get(section)} title={section.title} prefix={section.prefix} entries={section.entries} />
                        ) : (
                          <GenericTableView tableNumber={verificationTableNumbers.get(section)} title={section.title} headers={section.headers} rows={section.rows} />
                        )}
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="flex h-40 items-center justify-center rounded-lg border border-dashed">
                    <p class="text-sm text-muted-foreground">
                      No matching transcription section found.
                    </p>
                  </div>
                )}
              </div>
            </div>
          </section>
        </>
      );
    })}
  </div>

  <div class="mt-8 text-center">
    <a
      href="/bridge-docs/our-system/"
      class="text-sm font-medium text-primary underline-offset-4 hover:underline"
    >
      View complete transcribed system &rarr;
    </a>
  </div>
</BaseLayout>
