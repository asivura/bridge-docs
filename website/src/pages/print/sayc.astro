---
import PrintLayout from "@/layouts/PrintLayout.astro";
import { saycSystemSections } from "@/data/index";
import { diffExplanations, type DiffExplanation } from "@/data/difference-explanations";

// Map SAYC-SYSTEM.md section titles to diffExplanation section names
const sectionMap: Record<string, string> = {
  'Opening Bids': 'Opening Bids',
  'Defense After Opponent\'s Opening': 'Defense & Overcalls',
  'Ace Asking (4NT)': 'Blackwood (4NT)',
  'Responses to 1♣': 'Responses to 1♣',
  'Responses to 1♦': 'Responses to 1♦',
  'Responses to 1♥': 'Responses to 1♥',
  'Responses to 1♠': 'Responses to 1♠',
  'Responses to 1NT': 'Responses to 1NT',
  'Jacoby 2NT Convention': 'Jacoby 2NT Rebids',
  'Weak Two Bids': 'Conventions',
  'Competitive Bidding': 'Conventions',
};

// Build lookup: section title → matching explanations
function getAnnotations(title: string): DiffExplanation[] {
  const diffSection = sectionMap[title];
  if (!diffSection) return [];
  if (diffSection === 'Conventions') {
    // For sections mapped to "Conventions", match on bid keywords from section title
    const keyword = title.toLowerCase();
    return diffExplanations.filter(
      (d) => d.section === 'Conventions' && d.bid.toLowerCase().includes(keyword.split(' ')[0])
    );
  }
  return diffExplanations.filter((d) => d.section === diffSection);
}

// Group sections by page reference
const grouped = new Map<string, typeof saycSystemSections>();
for (const section of saycSystemSections) {
  const key = section.page || "Other";
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(section);
}

// Helper to colorize suit symbols
function formatBid(text: string): string {
  return text
    .replace(/♠/g, '<span class="suit-spade">♠</span>')
    .replace(/♣/g, '<span class="suit-club">♣</span>')
    .replace(/♥/g, '<span class="suit-heart">♥</span>')
    .replace(/♦/g, '<span class="suit-diamond">♦</span>');
}
---

<PrintLayout title="Standard SAYC — Convention Card">
  <div class="print-grid">
    {Array.from(grouped.entries()).map(([page, sections], groupIdx) => (
      <div class:list={["print-grid-item", groupIdx > 1 && ""]}>
        <div class="print-page-header">{page}</div>
        {sections.map((section) => (
          <div>
            <div class="print-section-header">{section.title}</div>
            <table class="print-table">
              <thead>
                <tr>
                  <th style="width: 30%">Bid</th>
                  <th style="width: 15%">HCP</th>
                  <th style="width: 55%">Description</th>
                </tr>
              </thead>
              <tbody>
                {section.entries.map((entry) => (
                  <tr>
                    <td set:html={formatBid(entry.bid)} />
                    <td>{entry.hcp}</td>
                    <td set:html={formatBid(entry.description)} />
                  </tr>
                ))}
              </tbody>
            </table>

            {(() => {
              const annotations = getAnnotations(section.title);
              return annotations.length > 0 && (
                <div class="diff-annotations-container">
                  {annotations.map((d) => (
                    <div class={`annotation-box annotation-${d.severity}`}>
                      <span class="annotation-label">{d.severity}</span>
                      {' '}
                      <strong set:html={formatBid(d.bid)} />:
                      {' '}{d.whatChanged}
                      {' '}<em>{d.practicalTip}</em>
                    </div>
                  ))}
                </div>
              );
            })()}
          </div>
        ))}
      </div>
    ))}
  </div>

</PrintLayout>
