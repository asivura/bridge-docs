---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ComparisonRow } from "@/components/ComparisonRow";
import { DiffBadge } from "@/components/DiffBadge";
import TableOfContents from "@/components/TableOfContents.astro";
import { comparisonSections } from "@/data/index";
import {
  Table,
  TableBody,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import "@/styles/global.css";

// Helper to colorize suit symbols
function formatBid(text: string): string {
  return text
    .replace(/♠/g, '<span class="suit-spade" style="color: inherit;">♠</span>')
    .replace(/♣/g, '<span class="suit-club" style="color: inherit;">♣</span>')
    .replace(/♥/g, '<span class="suit-heart" style="color: #dc2626;">♥</span>')
    .replace(/♦/g, '<span class="suit-diamond" style="color: #dc2626;">♦</span>');
}

const tocItems = comparisonSections.map((s) => ({
  id: s.title.toLowerCase().replace(/[^a-z0-9]+/g, "-"),
  label: s.title,
}));
---

<BaseLayout title="Comparison">
  <div class="space-y-2">
    <h1 class="text-3xl font-bold tracking-tight">Side-by-Side Comparison</h1>
    <p class="text-muted-foreground">
      Every bid compared between our partnership system and standard SAYC.
      Rows with differences are highlighted.
    </p>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-2 text-sm">
    <span class="text-muted-foreground">Legend:</span>
    <DiffBadge type="HCP" />
    <span class="text-muted-foreground">HCP range differs</span>
    <DiffBadge type="DESC" />
    <span class="text-muted-foreground">Description differs</span>
    <DiffBadge type="BOTH" />
    <span class="text-muted-foreground">Both differ</span>
    <DiffBadge type="NEW" />
    <span class="text-muted-foreground">Not in SAYC</span>
    <DiffBadge type="SAME" />
    <span class="text-muted-foreground">Identical</span>
  </div>

  <div class="mt-8 flex gap-8">
    <div class="min-w-0 flex-1 space-y-10">
      {comparisonSections.map((section) => (
        <div
          id={section.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}
          data-toc-target
          class="space-y-2 scroll-mt-4"
        >
          <h2 class="text-lg font-semibold" set:html={formatBid(section.title)} />
          <div class="overflow-x-auto">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead className="w-24">Bid</TableHead>
                  <TableHead>Our HCP</TableHead>
                  <TableHead>Our Description</TableHead>
                  <TableHead>SAYC HCP</TableHead>
                  <TableHead>SAYC Description</TableHead>
                  <TableHead className="w-20">Diff</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {section.entries.map((entry) => (
                  <ComparisonRow
                    bid={entry.bid}
                    ourHcp={entry.ourHcp}
                    ourDesc={entry.ourDescription}
                    saycHcp={entry.saycHcp}
                    saycDesc={entry.saycDescription}
                    diffType={entry.diffType || "SAME"}
                  />
                ))}
              </TableBody>
            </Table>
          </div>
        </div>
      ))}
    </div>

    <TableOfContents items={tocItems} />
  </div>
</BaseLayout>
